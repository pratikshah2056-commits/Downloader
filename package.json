{
  "name": "universal-media-downloader",
  "version": "1.0.0",
  "description": "A modern full-stack web application for downloading media from supported online platforms",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "keywords": [
    "media",
    "downloader",
    "youtube",
    "video",
    "audio"
  ],
  "license": "MIT",
  "dependencies": {
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.3"
  }
}
